{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "jsx": "react-jsx"
  },
  "include": ["src", "scripts", "agents", "mirror"]
}
