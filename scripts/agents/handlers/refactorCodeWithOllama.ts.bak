import fs from "fs";
import { runOllamaPrompt } from "../../shared/ollama";

export async function refactorCodeWithOllama(args: { path: string }) {
  const filePath = args?.path;
  if (!filePath || !fs.existsSync(filePath)) {
    return { status: "error", message: "File not found: " + filePath };
  }
  const code = fs.readFileSync(filePath, "utf8");
  const prompt = `
You are a senior developer. Refactor this code for readability and best practices.

Output only the refactored code.

\`\`\`ts
${code}
\`\`\`
`.trim();

  try {
    const refactored = await runOllamaPrompt(prompt);
    return { status: "success", refactored };
  } catch (err: any) {
    return { status: "error", message: err.message };
  }
}
